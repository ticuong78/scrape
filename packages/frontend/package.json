{
  "name": "@scrape/frontend",
  "private": true,
  "version": "1.0.0",
  "packageManager": "yarn@4.12.0",
  "main": ".vite/build/main.cjs",
  "type": "module",
  "author": {
    "name": "Lê Phạm Hùng Cường",
    "email": "cuongdayne17@gmail.com",
    "url": "https://www.facebook.com/hades.rander"
  },
  "description": "Đây là ứng dụng dùng để Scrape Trang Vàng Việt Nam. Ứng dụng lấy tên là WebScraper Pro để thể hiện sự cải tiến của nó so với các ứng dụng cũ của team đã build.",
  "scripts": {
    "dev": "vite",
    "dev:electron": "yarn build:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development node ../../node_modules/electron/cli.js --inspect=9229 dist-electron/main.cjs\"",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:all": "yarn build:electron && yarn build",
    "preview:electron": "yarn build:all && node ../../node_modules/electron/cli.js dist-electron/main.cjs",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish"
  },
